# ========================================
# Application Environment Configuration
# ========================================
# Environment: development, staging, or production
ENVIRONMENT=development

# Debug mode (only enable in development)
DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ========================================
# API Configuration
# ========================================
# Google Gemini API key (required)
GEMINI_API_KEY=your_google_gemini_api_key_here

# Gemini model to use
MODEL_NAME=gemini-2.5-flash

# ========================================
# Database Configuration (PostgreSQL)
# ========================================
# Database connection components
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=datalens

# Alternative: Full database URL (overrides individual settings above)
# DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:5432/datalens

# ========================================
# Redis Configuration
# ========================================
# Upstash Redis (recommended for production)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Alternative: Standard Redis URL (fallback)
# REDIS_URL=redis://username:password@host:port/0

# ========================================
# Application Configuration
# ========================================
# Maximum file upload size in MB
MAX_UPLOAD_MB=100

# Session time-to-live in seconds
SESSION_TTL_SECONDS=3600

# ========================================
# CORS Configuration
# ========================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Allow CORS credentials
CORS_ALLOW_CREDENTIALS=true

# ========================================
# Frontend Configuration (update URLs for production)
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ========================================
# Development Notes
# ========================================
# 1. Never commit actual credentials to version control
# 2. Use strong, unique passwords for production
# 3. Store sensitive values in environment variables or secret management
# 4. Update CORS origins for production domains
# 5. Use HTTPS URLs in production
